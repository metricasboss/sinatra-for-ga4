___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const injectScript = require('injectScript');
const setInWindow = require('setInWindow');
const log = require('logToConsole');

if (!data.accountId || !data.token) {
  log('Sinatra: accountId e token são obrigatórios.');
  return data.gtmOnFailure();
}

setInWindow('__sinatra', {
  accountId: data.accountId,
  token: data.token,
  measurementId: data.measurementId || '',
  debug: data.debug === true
}, true);

const SCRIPT_URL = 'https://gtm-templates.s3.us-east-1.amazonaws.com/sinatra-bundle.js';
injectScript(SCRIPT_URL, data.gtmOnSuccess, data.gtmOnFailure);


