___TESTS___

scenarios:
- name: Injeta script e salva config quando accountId e token estão presentes
  code: |
    const mockData = {
      accountId: 'metricasboss',
      token: 'abc123token',
      measurementId: 'G-TEST123',
      gtmOnSuccess: function() {},
      gtmOnFailure: function() {}
    };

    let savedKey, savedValue;
    mock('setInWindow', function(key, value) {
      savedKey = key;
      savedValue = value;
    });

    let injectedUrl;
    mock('injectScript', function(url, onSuccess) {
      injectedUrl = url;
      onSuccess();
    });

    runCode(mockData);

    assertThat(savedKey).isEqualTo('__sinatra');
    assertThat(savedValue.accountId).isEqualTo('metricasboss');
    assertThat(savedValue.token).isEqualTo('abc123token');
    assertThat(savedValue.measurementId).isEqualTo('G-TEST123');
    assertThat(injectedUrl).isEqualTo('https://gtm-templates.s3.us-east-1.amazonaws.com/sinatra-bundle.js');
    assertApi('gtmOnSuccess').wasCalled();

- name: Chama gtmOnFailure quando accountId ou token não está configurado
  code: |
    const mockData = {
      accountId: '',
      token: '',
      gtmOnSuccess: function() {},
      gtmOnFailure: function() {}
    };

    mock('setInWindow', function() {});
    mock('injectScript', function() {});

    runCode(mockData);

    assertApi('gtmOnFailure').wasCalled();
    assertApi('setInWindow').wasNotCalled();
    assertApi('injectScript').wasNotCalled();

- name: measurementId é opcional e usa string vazia como fallback
  code: |
    const mockData = {
      accountId: 'metricasboss',
      token: 'abc123token',
      gtmOnSuccess: function() {},
      gtmOnFailure: function() {}
    };

    let savedValue;
    mock('setInWindow', function(key, value) { savedValue = value; });
    mock('injectScript', function(url, onSuccess) { onSuccess(); });

    runCode(mockData);

    assertThat(savedValue.measurementId).isEqualTo('');
    assertApi('gtmOnSuccess').wasCalled();

- name: Chama gtmOnFailure quando injectScript falha
  code: |
    const mockData = {
      accountId: 'metricasboss',
      token: 'abc123token',
      gtmOnSuccess: function() {},
      gtmOnFailure: function() {}
    };

    mock('setInWindow', function() {});
    mock('injectScript', function(url, onSuccess, onFailure) { onFailure(); });

    runCode(mockData);

    assertApi('gtmOnFailure').wasCalled();
    assertApi('gtmOnSuccess').wasNotCalled();


___NOTES___

Created on 3/13/2025, 6:48:56 PM
Updated on 5/25/2026 - Rewrite: replaced addEventCallback/sendPixel approach with injectScript.
The template now injects sinatra.js which monkey-patches window.fetch and navigator.sendBeacon
to intercept GA4 hits (google-analytics.com/g/collect) and forward them to the Sinatra endpoint
as POST requests in GA4 Measurement Protocol format. This captures ALL GA4 params byte-for-byte
including browser-only fields (language, screen_resolution, session_id) that are unavailable
in the GTM sandbox.
